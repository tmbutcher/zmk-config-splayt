#include "splayt-layouts.dtsi"
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout_splayt;
        // zmk,matrix_transform = &matrix_transform0;
        // Other chosen items
    };

    kscan0: kscan_composite {
        compatible = "zmk,kscan-composite";
        rows = <6>;
        columns = <10>;

        // Include the matrix driver
        matrix {
            kscan = <&kscan1>;
        };

        // Include the direct GPIO driver...
        direct {
            kscan = <&kscan2>;
            row-offset = <5>;
        };
    };

    kscan1: kscan_matrix {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pro_micro 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    kscan2: kscan_direct {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;
        input-gpios = <&pro_micro 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };

    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <6>;
        map = <

//                              ╭─────────┬─────────┬─────────┬─────────╮       ╭─────────┬─────────┬─────────┬─────────╮
                                  RC(0,1)   RC(0,2)   RC(0,3)   RC(0,4)           RC(0,5)   RC(0,6)   RC(0,7)   RC(0,8)
//      ╭─────────┬─────────╮   ├─────────┼─────────┼─────────┼─────────┤       ├─────────┼─────────┼─────────┼─────────┤   ╭─────────┬─────────╮
          RC(1,0)   RC(0,0)       RC(1,1)   RC(1,2)   RC(1,3)   RC(1,4)           RC(1,5)   RC(1,6)   RC(1,7)   RC(1,8)       RC(0,9)   RC(1,9)
//      ├─────────┼─────────┤   ├─────────┼─────────┼─────────┼─────────┤       ├─────────┼─────────┼─────────┼─────────┤   ├─────────┼─────────┤
          RC(2,0)   RC(3,0)       RC(2,1)   RC(2,2)   RC(2,3)   RC(2,4)           RC(2,5)   RC(2,6)   RC(2,7)   RC(2,8)       RC(3,9)   RC(2,9)
//      ╰─────────┴─────────╯   ╰─────────┴─────────┴─────────┴─────────╯       ╰─────────┴─────────┴─────────┴─────────╯   ╰─────────┴─────────╯

//                              ╭─────────┬─────────┬─────────┬─────────╮       ╭─────────┬─────────┬─────────┬─────────╮
                                  RC(3,1)   RC(3,2)   RC(3,3)   RC(3,4)           RC(3,5)   RC(3,6)   RC(3,7)   RC(3,8)
//                              ╰─────────┴─────────┴─────────┴─────────╯       ╰─────────┴─────────┴─────────┴─────────╯

//      ╭─/*ENC*/─╮                       ╭─────────╮                                               ╭─────────╮                       ╭─/*ENC*/─╮
          RC(4,0)                           RC(4,1)                                                   RC(4,8)                          RC(4,9)
//      ╰─────────╯             ╭─────────╯ ─────── ╰─────────╮                           ╭─────────╯ ─────── ╰─────────╮             ╰─────────╯
                                  RC(4,3)   /*DPD*/   RC(4,2)                               RC(4,6)   /*DPD*/   RC(4,7)
//      ╭─/*CAP*/─╮             ╰─────────╮ ─────── ╭─────────╯                           ╰─────────╮ ─────── ╭─────────╯             ╭─/*CAP*/─╮
          RC(5,0)                           RC(4,4)                                                   RC(4,5)                           RC(5,9)
//      ╰─────────╯                       ╰─────────╯                                               ╰─────────╯                       ╰─────────╯
        >;
    };
};

&physical_layout_splayt {
    transform = <&matrix_transform0>;
};

// Encoders for all parts of the keyboard.
// If the encoder(s) are not behaving as expected,
// update steps and triggers-per-rotation to match your hardware.
// All pin assignments are done in the part overlays.

/ {
    encoder_left0: encoder_left0 {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
    };
    encoder_right0: encoder_right0 {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_left0 &encoder_right0>;
        triggers-per-rotation = <20>;
    };
};

// Input devices
/ {
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        input_split_right0: input_split_right0@0 {
            compatible = "zmk,input-split";
            reg = <0>;
            status = "disabled";
        };
    };

    input_listener_right0: input_listener_right0 {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&input_split_right0>;
    };

    trackball_listener {
    compatible = "zmk,input-listener";
    device = <&trackball>;
    };
};

